kind: Application
apiVersion: argoproj.io/v1alpha1
metadata:
    name: imgupadater
    namespace: argocd
    annotations:
        "argocd-image-updater.argoproj.io/image-list": "sumansahudockerhub/online:v1.0.0"
        "argocd-image-updater.argoproj.io/write-back-method": "git:secret:argocd/git-creds"
        "argocd-image-updater.argoproj.io/online.update-strategy": "semver"
spec:
  project: default
  source:
   repoURL: https://github.com/suman-kumarsahusu/argocd-in.git
   targetRevision: HEAD
   path: strategy
  destination:
   server: https://kubernetes.default.svc
   namespace: default
  syncPolicy: 
    automated:
     selfHeal: true
     prune: true
